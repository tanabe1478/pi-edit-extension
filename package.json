{
  "name": "pi-tagged-edit-extension",
  "version": "0.1.0",
  "description": "Experimental pi extension for checksum-tagged line edits and edit efficiency benchmarks.",
  "type": "module",
  "private": true,
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "bench": "node bench/bench.mjs",
    "bench:plan": "node bench/plan.mjs",
    "bench:parallel": "node bench/parallel-runner.mjs",
    "bench:report": "node bench/report.mjs",
    "bench:actual": "node bench/actual-runner.mjs",
    "bench:natural": "node bench/natural-runner.mjs",
    "bench:product": "node bench/product-runner.mjs",
    "bench:product-summary": "node bench/product-summary.mjs",
    "bench:collision": "node bench/collision.mjs",
    "bench:failure": "node bench/failure.mjs",
    "bench:fallback": "node bench/fallback.mjs",
    "bench:fallback-agent": "node bench/fallback-agent-runner.mjs",
    "scan:secrets": "gitleaks detect --source . --verbose --redact"
  },
  "keywords": ["pi", "extension", "llm", "edit", "checksum", "benchmark"],
  "license": "MIT",
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "typebox": "^1.0.55"
  }
}
